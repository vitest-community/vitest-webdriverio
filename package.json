{
  "name": "@vitest/browser-webdriverio",
  "type": "module",
  "version": "5.0.0-beta.5",
  "packageManager": "pnpm@11.6.0",
  "description": "Browser running for Vitest using webdriverio",
  "license": "MIT",
  "funding": "https://opencollective.com/vitest",
  "homepage": "https://vitest.dev/config/browser/webdriverio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitest-community/vitest-webdriverio.git"
  },
  "bugs": {
    "url": "https://github.com/vitest-community/vitest-webdriverio/issues"
  },
  "keywords": [
    "browser",
    "webdriverio",
    "wdio",
    "component",
    "mocks",
    "test",
    "testing"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./context": {
      "types": "./context.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "context.d.ts",
    "dist"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "scripts": {
    "build": "premove dist && rolldown -c",
    "dev": "rolldown -c --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:smoke": "vitest run",
    "release": "tsx scripts/release.ts",
    "publish-ci": "tsx scripts/publish-ci.ts"
  },
  "peerDependencies": {
    "vitest": "^5.0.0-beta.5",
    "webdriverio": "*"
  },
  "peerDependenciesMeta": {
    "webdriverio": {
      "optional": false
    }
  },
  "dependencies": {
    "@vitest/browser": "^5.0.0-beta.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "24.12.0",
    "@wdio/types": "^9.24.0",
    "bumpp": "^11.1.0",
    "changelogithub": "^14.0.0",
    "eslint": "^10.5.0",
    "pathe": "^2.0.3",
    "premove": "^4.0.0",
    "rolldown": "^1.1.3",
    "rolldown-plugin-dts": "^0.26.0",
    "semver": "^7.8.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "5.0.0-beta.5",
    "webdriverio": "^9.20.0",
    "zx": "^8.8.5"
  }
}
