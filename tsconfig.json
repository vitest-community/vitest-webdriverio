{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@vitest/browser-webdriverio": ["./src/index.ts"],
      "@vitest/browser-webdriverio/context": ["./context.d.ts"]
    },
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "stripInternal": true,
    "esModuleInterop": true,
    "isolatedDeclarations": true,
    "skipLibCheck": true
  },
  "include": ["src", "test"],
  "exclude": ["dist", "node_modules"]
}
